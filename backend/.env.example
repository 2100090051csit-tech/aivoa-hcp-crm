# LangGraph AI CRM Environment Configuration Template
# Copy this file to `.env` and fill in your keys.

# Go to https://console.groq.com to obtain your API key.
GROQ_API_KEY=your_actual_groq_api_key_here

# Groq Model to use (specified main: gemma2-9b-it, optional alternative: llama-3.3-70b-versatile)
GROQ_MODEL=gemma2-9b-it

# Database URL connection string.
# Default is SQLite for quick evaluation, but can point to PostgreSQL/MySQL.
# MySQL Example: mysql+pymysql://username:password@localhost:3306/aivoa_crm
DATABASE_URL=sqlite:///./crm.db
